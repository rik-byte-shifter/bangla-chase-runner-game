<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="description" content="Run, jump, and dodge in this hilarious chase game!">
    <meta property="og:title" content="Ma bolse durotto bojay rakhte">
    <meta property="og:description" content="Run, jump, and dodge in this hilarious chase runner game!">
    <meta property="og:type" content="website">
    <meta name="theme-color" content="#E67E22">
