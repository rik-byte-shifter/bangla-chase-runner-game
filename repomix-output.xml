<file path="css/style.css">
/* Catch Me If You Can - main styles */
:root {
    --primary: #E67E22;
    --secondary: #27AE60;
    --accent: #E74C3C;
    --sand: #F39C12;
    --brown-border: #8B4513;
    --ui-bg: rgba(0, 0, 0, 0.45);
}

* {
    box-sizing: border-box;
}

html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    overflow: hidden;
    font-family: Arial, Helvetica, sans-serif;
    background: var(--sand);
    touch-action: none;
    -webkit-tap-highlight-color: transparent;
}

body {
    display: flex;
    align-items: center;
    justify-content: center;
}

#game-container {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding:
        env(safe-area-inset-top, 0px)
        env(safe-area-inset-right, 0px)
        env(safe-area-inset-bottom, 0px)
        env(safe-area-inset-left, 0px);
    overflow: hidden;
    background: var(--sand);
}

#game-stage {
    position: relative;
    width: 1200px;
    height: 675px;
    transform: scale(var(--stage-scale, 1));
    transform-origin: center center;
}

#gameCanvas {
    display: block;
    width: 100%;
    height: 100%;
    border: 4px solid var(--brown-border);
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.3);
    background: #87CEEB;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
}

#ui-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    padding: 12px 16px;
    font-size: 14px;
    color: #fff;
    text-shadow: 1px 1px 2px #000;
}

#ui-layer > * {
    pointer-events: auto;
}

#player-profile {
    position: absolute;
    top: 12px;
    left: 16px;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    border: 5px solid #fff;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
    background: rgba(255, 255, 255, 0.15);
}

#player-profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

#score {
    position: absolute;
    top: 50px;
    left: 176px;
    font-size: 24px;
    font-weight: bold;
    color: #5D4037;
    text-shadow: 1px 1px 0 #fff;
}

#high-score-hud {
    position: absolute;
    top: 84px;
    left: 176px;
    font-size: 14px;
    color: #5D4037;
}

#lives {
    position: absolute;
    top: 12px;
    right: 120px;
    display: flex;
    gap: 4px;
    font-size: 28px;
    line-height: 1;
}

#speed-hud {
    position: absolute;
    bottom: 12px;
    right: 16px;
    font-size: 14px;
    color: #5D4037;
}

#mute-btn, #pause-btn {
    position: absolute;
    top: 8px;
    right: 16px;
    font-size: 22px;
    background: var(--ui-bg);
    border: 2px solid var(--brown-border);
    border-radius: 10px;
    padding: 4px 10px;
    cursor: pointer;
    transition: transform 0.15s ease;
}

#pause-btn {
    right: 64px;
}

#mute-btn:hover, #pause-btn:hover {
    transform: scale(1.05);
}

.screen {
    position: absolute;
    inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: rgba(243, 156, 18, 0.92);
    color: #2c1810;
    padding: 24px;
    z-index: 10;
}

.screen.active {
    display: flex;
}

/* Start menu: full-frame poster + overlaid actions */
#start-screen {
    padding: 0;
    justify-content: flex-end;
    background: #1a1208;
    overflow: hidden;
}

#start-screen .start-poster-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    z-index: 0;
    pointer-events: none;
}

#start-screen .start-poster-ui {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: clamp(20px, 5vw, 40px) 16px clamp(24px, 6vh, 48px);
    background: linear-gradient(to top, rgba(0, 0, 0, 0.72) 0%, rgba(0, 0, 0, 0.35) 55%, transparent 100%);
}

#start-screen .start-poster-ui.boot-loading {
    opacity: 0.92;
}

#start-screen .start-poster-btn {
    min-width: min(280px, 85vw);
    margin: 0;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), 0 4px 0 #a0521a;
}

#start-screen .start-poster-btn.btn-secondary {
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), 0 3px 0 #1e8449;
}

#start-screen .start-high-toast {
    margin: 4px 0 0;
    font-size: clamp(1rem, 3.5vw, 1.25rem);
    font-weight: bold;
    color: #fff;
    text-shadow: 0 1px 3px #000;
}

.intro-screen {
    padding: 0;
    background: #111;
    overflow: hidden;
}

.intro-screen .intro-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
    z-index: 0;
    pointer-events: none;
    background: #000;
}

.intro-screen .intro-ui {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 10px;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 12px;
}

.intro-screen .intro-btn {
    min-width: min(220px, 70vw);
    margin: 0;
}

#gameover-screen {
    padding: 0;
    background: transparent;
    overflow: hidden;
}

#gameover-screen .gameover-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    z-index: 0;
    pointer-events: none;
    filter: none;
}

#gameover-screen .gameover-ui {
    position: absolute;
    right: clamp(18px, 3.5vw, 48px);
    top: 62%;
    transform: translateY(-50%);
    z-index: 1;
    width: min(520px, 44vw);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 0;
    border-radius: 0;
    background: transparent;
    border: none;
    box-shadow: none;
}

#gameover-screen .gameover-line {
    margin: 0;
    padding: 10px 16px;
    border-radius: 14px;
    color: #ffffff;
    font-size: clamp(1.15rem, 2.8vw, 1.75rem);
    font-weight: 900;
    letter-spacing: 0.2px;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.72), rgba(0, 0, 0, 0.5));
    border: 2px solid rgba(255, 255, 255, 0.25);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.4);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.72);
}

#gameover-screen #final-score {
    display: inline-block;
    margin-left: 4px;
    font-size: 1.08em;
    font-weight: 900;
    color: #ffd66f;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.8), 0 0 6px rgba(255, 206, 90, 0.35);
}

#gameover-screen #achievements-panel {
    font-size: clamp(0.95rem, 1.9vw, 1.05rem);
    color: #d6f8e4;
}

#gameover-screen .gameover-btn {
    width: min(260px, 80vw);
    margin: 2px 0;
}

.title-font {
    font-family: 'Bangers', 'Press Start 2P', cursive, sans-serif;
    font-size: clamp(2rem, 6vw, 3.5rem);
    letter-spacing: 2px;
    margin: 0 0 16px;
    color: var(--accent);
    text-shadow: 2px 2px 0 #fff;
}

.caught {
    animation: pulse 0.8s ease-in-out infinite alternate;
}

@keyframes pulse {
    from { transform: scale(1); }
    to { transform: scale(1.08); }
}

.instructions {
    font-size: 16px;
    margin-bottom: 12px;
}

.high-score-line {
    font-size: 20px;
    font-weight: bold;
    margin: 14px 0 6px;
}

.btn-primary, .btn-secondary {
    font-family: 'Bangers', cursive, sans-serif;
    font-size: 1.5rem;
    padding: 14px 36px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    margin: 8px;
}

.btn-primary {
    background: var(--primary);
    color: #fff;
    box-shadow: 0 4px 0 #a0521a;
}

.btn-primary:hover {
    transform: scale(1.05);
}

.btn-primary:active {
    transform: scale(0.98);
    box-shadow: 0 2px 0 #a0521a;
}

.btn-secondary {
    background: var(--secondary);
    color: #fff;
    font-size: 1.1rem;
    box-shadow: 0 3px 0 #1e8449;
}

.btn-secondary:hover {
    transform: scale(1.05);
}

.hidden {
    display: none !important;
}

/* Pause UI must never appear on menu / intro / game-over (z-index was above those screens). */
#game-container:not(.gameplay-active) #pause-overlay {
    display: none !important;
    visibility: hidden;
    pointer-events: none;
}

#pause-overlay.hidden {
    display: none !important;
}

#pause-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 15;
    color: #fff;
    cursor: pointer;
    touch-action: manipulation;
    -webkit-user-select: none;
    user-select: none;
}

.pause-resume-hint {
    margin: 0;
    font-size: clamp(0.9rem, 3.5vw, 1.1rem);
    text-align: center;
    padding: 0 16px;
    line-height: 1.5;
}

.pause-resume-hint kbd {
    display: inline-block;
    padding: 0.15em 0.5em;
    font-size: 0.85em;
    font-family: inherit;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.45);
    background: rgba(0, 0, 0, 0.35);
}

/* Inside HUD layer so when #ui-layer is hidden (menu / intros / game-over), pause cannot appear. */
#ui-layer #pause-overlay {
    z-index: 100;
}

#pause-overlay .title-font {
    color: #fff;
    text-shadow: 2px 2px 0 #000;
}

#achievements-panel {
    max-width: 90%;
    font-size: 14px;
    color: #333;
}

#ui-layer.hidden {
    display: none;
}

/* ——— Mobile & small viewports ——— */
.btn-primary,
.btn-secondary,
.start-poster-btn,
.intro-btn,
.gameover-btn {
    touch-action: manipulation;
    min-height: 44px;
}

#start-screen .start-poster-ui {
    padding-bottom: max(clamp(24px, 6vh, 48px), env(safe-area-inset-bottom, 0px));
}

.intro-screen .intro-ui {
    bottom: max(10px, env(safe-area-inset-bottom, 0px));
    padding-left: max(12px, env(safe-area-inset-left, 0px));
    padding-right: max(12px, env(safe-area-inset-right, 0px));
}

@media (max-width: 640px) {
    #gameCanvas {
        border-width: 2px;
        box-shadow: 0 0 12px rgba(0, 0, 0, 0.25);
    }

    #gameover-screen .gameover-ui {
        left: 50%;
        right: auto;
        transform: translate(-50%, -50%);
        width: min(calc(100% - 24px), 420px);
        top: 56%;
        align-items: stretch;
    }

    #gameover-screen .gameover-line {
        font-size: clamp(0.95rem, 4.2vw, 1.35rem);
        padding: 8px 12px;
    }

    #gameover-screen #achievements-panel {
        font-size: clamp(0.8rem, 3.5vw, 0.95rem);
    }

    #gameover-screen .gameover-btn {
        width: 100%;
        max-width: 280px;
        margin-left: auto;
        margin-right: auto;
    }
}

@media (max-width: 520px) {
    #ui-layer {
        padding: 8px 10px;
    }

    #player-profile {
        top: 6px;
        left: 8px;
        width: clamp(48px, 14vw, 72px);
        height: clamp(48px, 14vw, 72px);
        border-width: 3px;
    }

    #score {
        top: 6px;
        left: clamp(58px, 14vw, 82px);
        right: 108px;
        font-size: clamp(0.85rem, 4vw, 1.1rem);
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    #high-score-hud {
        top: clamp(26px, 8vw, 34px);
        left: clamp(58px, 14vw, 82px);
        right: 108px;
        font-size: clamp(0.65rem, 2.8vw, 0.8rem);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    #lives {
        top: clamp(40px, 11vw, 52px);
        left: 8px;
        right: auto;
        font-size: clamp(1.1rem, 5vw, 1.4rem);
        gap: 2px;
    }

    #speed-hud {
        bottom: 6px;
        right: 8px;
        left: auto;
        font-size: clamp(0.65rem, 2.8vw, 0.75rem);
        max-width: 42%;
        text-align: right;
    }

    #mute-btn,
    #pause-btn {
        top: max(6px, env(safe-area-inset-top, 0px));
        min-width: 44px;
        min-height: 44px;
        padding: 6px 12px;
        font-size: 1.1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    #pause-btn {
        right: max(58px, calc(env(safe-area-inset-right, 0px) + 52px));
    }

    #mute-btn {
        right: max(8px, env(safe-area-inset-right, 0px));
    }
}

@media (max-width: 380px) {
    #score {
        right: 100px;
    }

    #high-score-hud {
        right: 100px;
    }

    #lives {
        top: auto;
        bottom: 40px;
        left: 8px;
        font-size: 1.15rem;
    }
}

/* Short landscape (phones): keep HUD out of the way */
@media (max-height: 420px) and (orientation: landscape) {
    #ui-layer {
        padding: 4px 8px;
    }

    #player-profile {
        width: 36px;
        height: 36px;
        border-width: 2px;
        top: 4px;
        left: 6px;
    }

    #score {
        top: 4px;
        left: 46px;
        right: 96px;
        font-size: 0.8rem;
    }

    #high-score-hud {
        top: 22px;
        left: 46px;
        right: 96px;
        font-size: 0.6rem;
    }

    #lives {
        top: auto;
        bottom: 4px;
        left: 6px;
        font-size: 1rem;
    }

    #speed-hud {
        bottom: 4px;
        right: 6px;
        font-size: 0.6rem;
    }

    #mute-btn,
    #pause-btn {
        top: 4px;
        min-width: 40px;
        min-height: 40px;
        padding: 4px 8px;
        font-size: 1rem;
    }

    #pause-btn {
        right: 50px;
    }

    #mute-btn {
        right: 6px;
    }
}

@media (orientation: landscape) and (max-height: 500px) {
    #ui-layer {
        padding-left: max(10px, env(safe-area-inset-left, 0px));
        padding-right: max(10px, env(safe-area-inset-right, 0px));
    }
}
